{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clawcost",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "landing"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "getclawcost.com/*",
      "zone_name": "getclawcost.com"
    },
    {
      "pattern": "www.getclawcost.com/*",
      "zone_name": "getclawcost.com"
    }
  ]
}
