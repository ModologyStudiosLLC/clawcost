# ClawCost Configuration
# Copy this to .env and adjust values

# Port the proxy listens on (default: 4100)
CLAWCOST_PORT=4100

# Spending budgets in USD
CLAWCOST_DAILY_BUDGET=5.00
CLAWCOST_MONTHLY_BUDGET=50.00

# Where to store the SQLite database (default: ~/.clawcost/)
# CLAWCOST_DATA_DIR=/path/to/data

# Dashboard API key (optional — leave empty for no auth)
# If set, all dashboard API routes require Authorization: Bearer <key>
# Generate a key: node -e "console.log('cc_' + require('crypto').randomBytes(16).toString('hex'))"
# CLAWCOST_DASHBOARD_KEY=cc_your_key_here

# Dynamic pricing is stored in ~/.clawcost/pricing.json
# Edit that file to update model prices without code changes
