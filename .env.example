# ClawCost Configuration
# Copy this to .env and adjust values

# Port the proxy listens on (default: 4100)
CLAWCOST_PORT=4100

# Spending budgets in USD
CLAWCOST_DAILY_BUDGET=5.00
CLAWCOST_MONTHLY_BUDGET=50.00

# Where to store the SQLite database (default: ~/.clawcost/)
# CLAWCOST_DATA_DIR=/path/to/data
